rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isNotBanned() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid))
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned != true;
    }

    function isVerifiedUser() {
      return isAuthenticated() && isNotBanned() && request.auth.token.email_verified == true;
    }

    function isFriend(userId) {
      return exists(/databases/$(database)/documents/friendships/$(request.auth.uid)/friends/$(userId))
        && get(/databases/$(database)/documents/friendships/$(request.auth.uid)/friends/$(userId)).data.status == 'accepted';
    }

    function isLeagueMember(leagueId) {
      return exists(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid));
    }

    function isLeagueAdmin(leagueId) {
      return isLeagueMember(leagueId)
        && get(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidUsername(username) {
      return username.size() >= 3 && username.size() <= 20;
    }

    // USERS
    // Read is open to authenticated users so global leaderboards and profile
    // previews can query/list (Firestore rejects collection queries when the
    // rule depends on resource.data). Per-user privacy is handled in UI.
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) && isNotBanned()
        && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['uid', 'email', 'isBanned', 'isPremium']);
      allow delete: if false;
    }

    // USERNAME UNIQUENESS INDEX
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && isValidUsername(username);
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // FRIENDSHIPS
    match /friendships/{userId}/friends/{friendId} {
      allow read: if isAuthenticated();
      allow create: if (isOwner(userId) || isOwner(friendId)) && isVerifiedUser();
      allow update: if (isOwner(userId) || isOwner(friendId))
        && isVerifiedUser();
      allow delete: if isOwner(userId) || isOwner(friendId);
    }

    // HABITS
    match /habits/{userId}/userHabits/{habitId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && isNotBanned();
      allow delete: if isOwner(userId);
    }

    // LOGS
    match /logs/{userId}/habitLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isNotBanned();
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // DIET LOG ENTRIES (meal-by-meal calorie/macro tracking)
    // Private to the user — diet data is sensitive, no global read.
    match /dietLogs/{userId}/entries/{entryId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && isNotBanned();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // DIET QUOTAS (rate-limit counters for the AI parse endpoint)
    // Read-only from the client — only the parseFoodWithClaude
    // Cloud Function (running as admin) writes to this collection.
    match /dietQuotas/{userId} {
      allow read:  if isOwner(userId);
      allow write: if false;
    }

    // LEADERBOARDS
    match /leaderboards/{categorySlug}/{period}/{entryUserId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(entryUserId);
    }

    // LEAGUES
    match /leagues/{leagueId} {
      allow read: if isAuthenticated() && (
        !resource.data.isPrivate || isLeagueMember(leagueId)
      );
      allow create: if isVerifiedUser();
      allow update: if isLeagueAdmin(leagueId);
      allow delete: if isLeagueAdmin(leagueId);
    }

    match /leagues/{leagueId}/members/{userId} {
      allow read: if isLeagueMember(leagueId);
      allow create: if isOwner(userId) && isVerifiedUser();
      allow delete: if isOwner(userId) || isLeagueAdmin(leagueId);
      allow update: if isLeagueAdmin(leagueId);
    }

    // COMPETITIONS
    match /competitions/{competitionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // FEED
    match /feed/{userId}/items/{itemId} {
      allow read: if isOwner(userId) || isFriend(userId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // RECAPS — one per (user, local-date). Doc id IS the YYYY-MM-DD date
    // string. Drafts (status == 'draft') are private to the owner; once
    // published, friends can read. Only the owner can write — clients
    // mutate via `lib/recap.ts`. Edit-after-publish window is enforced
    // client-side (24h); the rule allows updates from the owner anytime.
    match /recaps/{userId}/items/{recapId} {
      allow read: if isOwner(userId)
        || (isFriend(userId) && resource.data.status == 'published');
      allow create: if isOwner(userId) && isNotBanned();
      allow update: if isOwner(userId) && isNotBanned();
      allow delete: if false;
    }

    // GYM WORKOUTS — owner-only. The workout doc lives at
    // gymWorkouts/{uid}/items/{workoutId} and is mutated mid-session
    // by the active-workout page. Friends don't read these directly;
    // a workout's summary surfaces through the gym pillar's recap
    // entry instead.
    match /gymWorkouts/{userId}/items/{workoutId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isNotBanned();
      allow update: if isOwner(userId) && isNotBanned();
      allow delete: if isOwner(userId);
    }

    // PACTS — top-level docs shared between two participants. Either
    // can read; updates restricted to legitimate transitions because
    // earlier rules let either participant flip status to
    // 'succeeded'/'broken' directly and self-grant rewards.
    //
    // Allowed client transitions:
    //   pending → active   (only the recipient — not the initiator)
    //   pending → declined (either participant)
    //   active → active    (dayStatus + freeze fields, no status change)
    //
    // Resolution to succeeded/broken happens in the resolvePact Cloud
    // Function (admin SDK bypasses rules). Clients can never write
    // those states directly.
    match /pacts/{pactId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isNotBanned()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.status == 'pending'
        && request.resource.data.participants.size() == 2;
      allow update: if isAuthenticated() && isNotBanned()
        && request.auth.uid in resource.data.participants
        // Block client-side resolution flips — admin SDK in
        // resolvePact handles these.
        && !(request.resource.data.status in ['succeeded', 'broken'])
        // The initiator can't accept their own pact (pending → active).
        // They can still flip to declined, or modify dayStatus on an
        // already-active pact.
        && !(resource.data.status == 'pending'
             && request.resource.data.status == 'active'
             && request.auth.uid == resource.data.initiatorId);
      allow delete: if false;
    }

    // FRIENDS LEAGUE SNAPSHOTS — weekly settlement docs. Owner-readable;
    // writes only via the admin SDK from the friendsLeagueSettle Cloud
    // Function (rules deny direct client writes — keeps the reward
    // payout off-limits to forgery).
    match /friendsLeagues/{userId}/items/{weekKey} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // NOTIFICATIONS
    match /notifications/{userId}/items/{notificationId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create: if isAuthenticated();
      allow delete: if false;
    }

    // BADGES (read-only catalog)
    match /badges/{badgeId} {
      allow read: if true;
      allow write: if false;
    }

    match /userBadges/{userId}/earned/{badgeId} {
      allow read: if isOwner(userId) || isFriend(userId);
      // Owner can create badge entries client-side (since onLogCreated
      // moved to logHabit.ts client-side; same trust precedent as XP).
      // Earned badges are immutable once created — no update/delete.
      allow create: if isOwner(userId) && isNotBanned();
      allow update, delete: if false;
    }

    // REPORTS
    match /reports/{reportId} {
      allow create: if isVerifiedUser();
      allow read: if false;
      allow update: if false;
      allow delete: if false;
    }

    // SHARED REACTIONS
    match /reactions/{reactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // COMMENTS — subcollection under reactions/{originId}/comments
    match /reactions/{reactionId}/comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // GROUPS — public communities ("Runners", "Early Risers", etc.)
    match /groups/{groupId} {
      allow read: if true;
      allow create: if isVerifiedUser();
      allow update: if isAuthenticated();
      allow delete: if false;
    }
    match /groups/{groupId}/members/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // TOURNAMENTS
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // AUDIT LOGS
    match /auditLogs/{logId} {
      allow read: if false;
      allow write: if false;
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    // SCHEDULE — weekly habit planner, owner-only
    match /scheduleEntries/{userId}/items/{entryId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // MESSAGES — direct 1:1 chat between friends.
    // Thread id = alphabetically-sorted(uidA, uidB) joined by '_'. Each
    // message carries the participants array so list queries can filter
    // `array-contains` on the current user and the security rule can
    // check membership without a document fetch.
    //
    // Note: gated on isAuthenticated + isNotBanned (NOT isVerifiedUser) —
    // requiring email verification blocks messaging for anyone who
    // didn't verify at signup, which was the original "click send and
    // nothing happens" bug.
    match /messages/{threadId}/items/{messageId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isNotBanned()
        && request.resource.data.senderId == request.auth.uid
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update, delete: if false;
    }

    // MESSAGE THREADS — metadata doc per pair (lastMessage, lastAt,
    // unread-by-participant). Either participant can read + write.
    match /messageThreads/{threadId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isNotBanned()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if false;
    }
  }
}
